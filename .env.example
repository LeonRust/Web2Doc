# Web2Doc LLM / 代理 配置示例
# 用法：复制本文件为 .env 并填入你的真实值
#   cp .env.example .env
#
# 优先级：CLI 参数 > shell 环境变量 > .env > 配置文件(config.toml) > 默认值
# 注意：.env 不会覆盖已在 shell 中导出的同名环境变量。

# LLM 端点（OpenAI 兼容协议）。默认 https://api.deepseek.com
LLM_BASE_URL=https://api.deepseek.com

# LLM 模型名。默认 deepseek-v4-flash
LLM_MODEL=deepseek-v4-flash

# LLM API Key。设置后才启用 LLM 站点级规则分析；请替换为你的真实 Key。
LLM_API_KEY=sk-your-api-key-here

# 出站代理（标准变量名，按需取消注释）。支持 http/https/socks5。
# 同时作用于静态引擎(reqwest)与动态引擎(Chrome)；Chrome 暂不支持带认证的代理。
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:1080
# NO_PROXY=localhost,127.0.0.1,*.internal
